# Copie este arquivo para .env e preencha com os seus valores reais.
# O .env fica fora do controle de versao (veja o .gitignore).

# Chave da API da Anthropic (obrigatoria)
ANTHROPIC_API_KEY=

# Modelo a usar (opcional). Se nao definir, o padrao e claude-opus-4-8.
# Alternativa mais barata, se quiser economizar credito: claude-sonnet-5
ANTHROPIC_MODEL=claude-opus-4-8
